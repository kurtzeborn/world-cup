{
  "routes": [
    { "route": "/.auth/login/aad", "rewrite": "/.auth/login/aad" },
    { "route": "/.auth/login/google", "rewrite": "/.auth/login/google" },
    { "route": "/.auth/logout", "rewrite": "/.auth/logout" },
    { "route": "/api/teams", "allowedRoles": ["anonymous", "authenticated"] },
    { "route": "/api/roles", "allowedRoles": ["anonymous", "authenticated"] },
    { "route": "/api/*", "allowedRoles": ["authenticated"] },
    { "route": "/admin", "allowedRoles": ["admin"] },
    { "route": "/admin/*", "allowedRoles": ["admin"] }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/.auth/*", "/assets/*", "*.js", "*.css", "*.svg", "*.png", "*.jpg", "*.ico", "*.woff2"]
  },
  "responseOverrides": {
    "401": { "statusCode": 302, "redirect": "/" },
    "403": { "statusCode": 302, "redirect": "/" }
  },
  "auth": {
    "rolesSource": "/api/roles",
    "identityProviders": {
      "azureActiveDirectory": {
        "registration": {
          "openIdIssuer": "https://login.microsoftonline.com/d000bf25-a578-4f6f-b00c-75dea4407da7/v2.0",
          "clientIdSettingName": "AZURE_CLIENT_ID",
          "clientSecretSettingName": "AZURE_CLIENT_SECRET"
        }
      },
      "google": {
        "registration": {
          "clientIdSettingName": "GOOGLE_CLIENT_ID",
          "clientSecretSettingName": "GOOGLE_CLIENT_SECRET"
        }
      }
    }
  }
}
